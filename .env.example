# Firebase web app config. Use the values from Firebase > Project settings > Your apps > Web app.
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_FIREBASE_APP_ID"
VITE_FIREBASE_MEASUREMENT_ID="YOUR_MEASUREMENT_ID"

# Server-side only. Configure it in Vercel project env vars.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Firebase Admin SDK. Use either the JSON blob or the split variables below.
FIREBASE_ADMIN_CREDENTIALS='{"projectId":"YOUR_PROJECT_ID","clientEmail":"firebase-adminsdk@YOUR_PROJECT_ID.iam.gserviceaccount.com","privateKey":"-----BEGIN PRIVATE KEY-----\\nYOUR_PRIVATE_KEY\\n-----END PRIVATE KEY-----\\n"}'
FIREBASE_ADMIN_PROJECT_ID="YOUR_PROJECT_ID"
FIREBASE_ADMIN_CLIENT_EMAIL="firebase-adminsdk@YOUR_PROJECT_ID.iam.gserviceaccount.com"
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\nYOUR_PRIVATE_KEY\\n-----END PRIVATE KEY-----\\n"

# Required for admin-only API routes such as lead-stage.
ADMIN_EMAILS="admin@tu-dominio.com"

# Optional. Override the model used by the AI commercial analyst.
AI_ANALYST_MODEL="gemini-2.0-flash"

# Public app URL if you need it for links or callbacks.
APP_URL="https://tu-dominio.com"

# ── Fase 01: Seguridad ──────────────────────────────────────────────────────

# Allowed origin for lead-strategy endpoint (strict origin check in production)
ALLOWED_ORIGIN="https://weblayercloud.com"

# Cloudflare Turnstile CAPTCHA for contact form
TURNSTILE_SECRET_KEY="YOUR_TURNSTILE_SECRET_KEY"
VITE_TURNSTILE_SITE_KEY="YOUR_TURNSTILE_SITE_KEY"

# ── Fase 02: Follow-up automático ───────────────────────────────────────────

# Resend email service (https://resend.com)
RESEND_API_KEY="re_xxxx"
FROM_EMAIL="LayerCloud <hola@weblayercloud.com>"

# Internal team notifications (at least one recommended)
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/xxx"
TELEGRAM_WEBHOOK_URL="https://api.telegram.org/botTOKEN/sendMessage"
TELEGRAM_CHAT_ID="xxx"

# Admin panel URL for notification links
ADMIN_URL="https://weblayercloud.com/admin"
